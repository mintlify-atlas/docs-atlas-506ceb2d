  "keyFeatures": [
    "User registration and authentication with Supabase",
    "Admin dashboard for managing speakers, conferences, and system settings",
    "Conference enrollment and QR code generation for attendees",
    "Dynamic theming system with country-based visual customization",
    "Real-time synchronization between admin panel and public pages",
    "Image upload for speaker profiles",
    "Recovery system for deleted conferences",
    "Performance monitoring and resource tracking"
  ],
  "publicApiSurface": [
    "POST /api/usuarios/register - User registration",
    "GET /api/usuarios/perfil - Get user profile",
    "POST /api/usuarios/perfil - Create user profile",
    "PUT /api/usuarios/perfil - Update user profile",
    "GET /api/eventos - List all events",
    "POST /api/eventos - Create new event",
    "GET /api/ponencias - List all conferences",
    "POST /api/ponencias - Create new conference",
    "PUT /api/ponencias/:id - Update conference",
    "DELETE /api/ponencias/:id - Delete conference",
    "GET /api/ponentes - List all speakers",
    "POST /api/ponentes - Create new speaker",
    "POST /api/inscripciones - Enroll in conference",
    "GET /api/inscripciones/mis-inscripciones - Get user enrollments"
  ]
